## Plantilla .gitignore de Seb
# Puedes encontrar la versión más actualizada en https://go.sebastiano.dev/gitignore
# Basado en parte en plantillas de https://plugins.jetbrains.com/plugin/7495--ignore
# Publicado bajo una licencia CC-0 https://creativecommons.org/share-your-work/public-domain/cc0/

### Plantilla de Windows
# Archivos de caché de miniaturas de Windows
Thumbs.db
Thumbs.db:encriptable
ehthumbs.db
ehthumbs_vista.db

# Archivo de volcado
*.stackdump

# Archivo de configuración de carpeta
[dd]esktop.ini

# Papelera de reciclaje utilizada en recursos compartidos de archivos
$RECYCLE. BOTE/

# Archivos de Windows Installer
*.taxi
*.Msi
*.msix
*.Msm
*.Msp

# Atajos de Windows
*.lnk

### Plantilla de macOS
# General
.DS_Store
. ManzanaDoble
. LSOverride

# El icono debe terminar con dos \r
Icono

# Miniaturas
._*

# Archivos que pueden aparecer en la raíz de un volumen
. DocumentRevisions-V100
.fseventsd
. Foco-V100
. Elementos temporales
. Destroza
. VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directorios potencialmente creados en el uso compartido remoto de AFP
. AppleDB
. AppleDesktop (Escritorio de Apple)
Carpeta Papelera  de red
Artículos temporales
.apdisk

### Plantilla de Linux
*~

# archivos temporales que se pueden crear si un proceso todavía tiene un identificador abierto de un archivo eliminado
.fuse_hidden*

# Preferencias del directorio de KDE
.directorio

# Carpeta de papelera de Linux que puede aparecer en cualquier partición o disco
. Basura-*

# Los archivos .nfs se crean cuando se elimina un archivo abierto pero se sigue accediendo
.Nfs*

### Plantilla de JetBrains
# Cubre los IDE de JetBrains: IntelliJ, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio y WebStorm
# Referencia: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839

*.iml
*.Ipr
*.Iws
/.idea/*

# Excluir cosas no específicas del usuario
!.idea/.nombre
!.idea/codeInsightSettings.xml
!.idea/codeStyles/
!.idea/derechos de autor/
!.idea/dataSources.xml
!.idea/detekt.xml
!.idea/encodings.xml
!.idea/externalDependencies.xml
!.idea/file.template.settings.xml
!.idea/archivoPlantillas/
!.idea/icon.svg
!.idea/inspectionProfiles/
!.idea/runConfigurations/
!.idea/alcances/
!.idea/vcs.xml

### Plantilla de Kotlin
# Archivo de clase compilado
*.clase

# Archivo de registro
*.registro

# Archivos de paquete #
*.tarro
*.guerra
*.Nar
*.oreja
*.cremallera
*.tar.gz
*.Rar

# Registros de fallas de máquinas virtuales, consulte http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

### Plantilla de Gradle
.gradle

# Tenga en cuenta que es posible que deba excluir a mano otras carpetas
# named build si es necesario (por ejemplo, en src/)
**/construir/

# Evita ignorar el archivo jar del contenedor de Gradle (.jar archivos generalmente se ignoran)
!gradle/envoltorio/gradle-wrapper.jar

# Caché del proyecto
.gradletasknamecache